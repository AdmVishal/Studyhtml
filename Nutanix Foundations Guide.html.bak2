      <div class="cheat-card-header"><span class="icon">🌐</span><h4>Key Port Reference</h4></div>
      <div class="cheat-card-body">
        <div class="cheat-row"><span class="ck">9440</span><span class="cv">Prism UI / REST API (HTTPS)</span></div>
        <div class="cheat-row"><span class="ck">22</span><span class="cv">SSH (CVM & AHV host)</span></div>
        <div class="cheat-row"><span class="ck">2049</span><span class="cv">NFS (hypervisor → CVM)</span></div>
        <div class="cheat-row"><span class="ck">3260</span><span class="cv">iSCSI data path</span></div>
        <div class="cheat-row"><span class="ck">2100</span><span class="cv">Zookeeper quorum</span></div>
        <div class="cheat-row"><span class="ck">2888/3888</span><span class="cv">Zookeeper leader election</span></div>
        <div class="cheat-row"><span class="ck">8000</span><span class="cv">Foundation web UI</span></div>
        <div class="cheat-row"><span class="ck">80/443</span><span class="cv">Pulse, LCM, external comms</span></div>
      </div>
    </div>
    <div class="cheat-card">
      <div class="cheat-card-header"><span class="icon">⬆️</span><h4>LCM Upgrade Safety Order</h4></div>
      <div class="cheat-card-body">
        <div class="cheat-row"><span class="ck">Step 1</span><span class="cv">NCC (health check plugin)</span></div>
        <div class="cheat-row"><span class="ck">Step 2</span><span class="cv">Foundation</span></div>
        <div class="cheat-row"><span class="ck">Step 3</span><span class="cv">AOS (cluster software)</span></div>
        <div class="cheat-row"><span class="ck">Step 4</span><span class="cv">AHV Hypervisor</span></div>
