<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>OS Admin L3 — Interview Preparation Hub</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0e1a;
  --surface: #111827;
  --surface2: #1a2236;
  --surface3: #1f2d45;
  --border: #1e3a5f;
  --accent: #00d4ff;
  --accent2: #3b82f6;
  --accent3: #10b981;
  --accent4: #f59e0b;
  --accent5: #ef4444;
  --accent6: #8b5cf6;
  --text: #e2e8f0;
  --text2: #94a3b8;
  --text3: #64748b;
  --mono: 'JetBrains Mono', monospace;
  --head: 'Syne', sans-serif;
  --body: 'Inter', sans-serif;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HEADER ── */
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(10,14,26,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  height: 60px;
}
.header-brand {
  display: flex; align-items: center; gap: 12px;
}
.header-logo {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--head); font-weight: 800; font-size: 14px; color: #000;
}
.header-title { font-family: var(--head); font-weight: 700; font-size: 1rem; color: var(--text); }
.header-sub { font-size: 0.7rem; color: var(--text3); font-family: var(--mono); }
.header-stats { display: flex; gap: 1.5rem; }
.hstat { text-align: center; }
.hstat-n { font-family: var(--head); font-weight: 800; font-size: 1.1rem; color: var(--accent); }
.hstat-l { font-size: 0.65rem; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; }

/* ── LAYOUT ── */
.layout {
  display: flex;
  padding-top: 60px;
  min-height: 100vh;
}

/* ── SIDEBAR ── */
.sidebar {
  width: 260px; min-width: 260px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  height: calc(100vh - 60px);
  position: sticky; top: 60px;
  overflow-y: auto;
  padding: 1rem 0;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.sidebar-section { margin-bottom: 0.25rem; }
.sidebar-section-header {
  padding: 0.5rem 1rem;
  font-size: 0.65rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--text3);
  font-family: var(--mono);
  margin-top: 0.5rem;
}
.sidebar-item {
  display: flex; align-items: center; gap: 10px;
  padding: 0.6rem 1rem;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: all 0.15s;
  font-size: 0.82rem;
  color: var(--text2);
}
.sidebar-item:hover { background: var(--surface2); color: var(--text); border-left-color: var(--border); }
.sidebar-item.active { background: rgba(0,212,255,0.08); color: var(--accent); border-left-color: var(--accent); }
.sidebar-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.sidebar-count {
  margin-left: auto;
  background: var(--surface3);
  border-radius: 10px;
  padding: 1px 7px;
  font-size: 0.65rem;
  color: var(--text3);
  font-family: var(--mono);
}
.sidebar-item.active .sidebar-count { background: rgba(0,212,255,0.15); color: var(--accent); }

/* ── MAIN CONTENT ── */
.main {
  flex: 1;
  overflow-y: auto;
  padding: 2rem;
}
.main::-webkit-scrollbar { width: 6px; }
.main::-webkit-scrollbar-track { background: transparent; }
.main::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* ── TAB PANEL ── */
.tab-panel { display: none; animation: fadeIn 0.3s ease; }
.tab-panel.active { display: block; }
@keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

/* ── PAGE HEADER ── */
.page-header {
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}
.page-header-row { display: flex; align-items: flex-start; gap: 1rem; }
.page-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem; flex-shrink: 0;
}
.page-title { font-family: var(--head); font-weight: 800; font-size: 1.6rem; color: var(--text); }
.page-desc { font-size: 0.85rem; color: var(--text2); margin-top: 0.25rem; line-height: 1.5; }
.page-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
.tag {
  padding: 2px 10px; border-radius: 20px;
  font-size: 0.7rem; font-family: var(--mono);
  border: 1px solid;
}

/* ── QUESTION CARD ── */
.q-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  margin-bottom: 1.25rem;
  overflow: hidden;
  transition: border-color 0.2s;
}
.q-card:hover { border-color: rgba(0,212,255,0.3); }
.q-card.critical { border-left: 3px solid var(--accent5); }
.q-card.scenario { border-left: 3px solid var(--accent4); }
.q-card.concept { border-left: 3px solid var(--accent2); }
.q-card.command { border-left: 3px solid var(--accent3); }

.q-header {
  display: flex; align-items: flex-start; gap: 0.75rem;
  padding: 1rem 1.25rem;
  cursor: pointer;
  user-select: none;
}
.q-num {
  font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
  color: var(--text3); flex-shrink: 0; padding-top: 2px;
  min-width: 28px;
}
.q-badge {
  flex-shrink: 0;
  padding: 2px 8px; border-radius: 4px;
  font-size: 0.62rem; font-family: var(--mono); font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.05em;
}
.badge-critical { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
.badge-scenario { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); }
.badge-concept  { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
.badge-command  { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3); }
.badge-general  { background: rgba(139,92,246,0.15); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3); }

.q-text {
  font-weight: 500; font-size: 0.9rem; color: var(--text); flex: 1; line-height: 1.5;
}
.q-chevron {
  flex-shrink: 0; color: var(--text3); font-size: 1rem;
  transition: transform 0.25s; margin-left: auto; padding-top: 2px;
}
.q-card.open .q-chevron { transform: rotate(180deg); color: var(--accent); }

.q-body {
  display: none;
  padding: 0 1.25rem 1.25rem;
  border-top: 1px solid var(--border);
}
.q-card.open .q-body { display: block; }

.answer-label {
  font-family: var(--mono); font-size: 0.7rem; color: var(--accent2);
  text-transform: uppercase; letter-spacing: 0.08em;
  margin: 1rem 0 0.5rem;
}
.answer-text { font-size: 0.875rem; color: var(--text2); line-height: 1.7; }

.code-block {
  background: #0d1117;
  border: 1px solid #1e3a5f;
  border-radius: 8px;
  padding: 0.9rem 1rem;
  margin: 0.75rem 0;
  font-family: var(--mono);
  font-size: 0.78rem;
  line-height: 1.7;
  overflow-x: auto;
  position: relative;
}
.code-block .comment { color: #6e8098; }
.code-block .cmd { color: #79c0ff; }
.code-block .flag { color: #ffa657; }
.code-block .string { color: #a5d6ff; }
.code-block .output { color: #56d364; }
.code-block .separator { color: #30363d; }

.step-list { list-style: none; margin: 0.5rem 0; }
.step-list li {
  display: flex; gap: 0.75rem; align-items: flex-start;
  padding: 0.4rem 0;
  font-size: 0.875rem; color: var(--text2); line-height: 1.6;
}
.step-list li::before {
  content: '▸';
  color: var(--accent); flex-shrink: 0; font-size: 0.75rem; margin-top: 3px;
}
.step-list li.warn::before { color: var(--accent4); }
.step-list li.danger::before { color: var(--accent5); }
.step-list li.good::before { color: var(--accent3); }

.tip-box {
  background: rgba(245,158,11,0.08);
  border: 1px solid rgba(245,158,11,0.25);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-top: 0.75rem;
  font-size: 0.82rem;
  color: #fbbf24;
  display: flex; gap: 0.5rem; align-items: flex-start;
}
.tip-box::before { content: '★'; flex-shrink: 0; }

.warn-box {
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.25);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-top: 0.75rem;
  font-size: 0.82rem;
  color: #f87171;
  display: flex; gap: 0.5rem; align-items: flex-start;
}
.warn-box::before { content: '⚠'; flex-shrink: 0; }

.info-box {
  background: rgba(59,130,246,0.08);
  border: 1px solid rgba(59,130,246,0.25);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-top: 0.75rem;
  font-size: 0.82rem;
  color: #60a5fa;
}

.section-divider {
  font-family: var(--mono); font-size: 0.72rem; font-weight: 600;
  color: var(--accent3); text-transform: uppercase; letter-spacing: 0.08em;
  margin: 1rem 0 0.6rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.section-divider::after { content: ''; flex: 1; height: 1px; background: rgba(16,185,129,0.2); }

.sub-answer { font-size: 0.875rem; color: var(--text2); line-height: 1.7; margin-bottom: 0.5rem; }
.sub-title { font-size: 0.8rem; font-weight: 600; color: var(--accent4); margin: 0.75rem 0 0.3rem; font-family: var(--mono); }

/* ── TABLE ── */
.data-table { width: 100%; border-collapse: collapse; margin: 0.75rem 0; font-size: 0.8rem; }
.data-table th {
  background: var(--surface3); color: var(--text); font-family: var(--mono);
  padding: 0.5rem 0.75rem; text-align: left; font-weight: 600;
  border: 1px solid var(--border); font-size: 0.75rem;
}
.data-table td {
  padding: 0.45rem 0.75rem; border: 1px solid var(--border);
  color: var(--text2); vertical-align: top; line-height: 1.5;
}
.data-table tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
.data-table td.mono { font-family: var(--mono); font-size: 0.75rem; color: #79c0ff; }
.data-table td.green { color: #34d399; }
.data-table td.yellow { color: #fbbf24; }
.data-table td.red { color: #f87171; }

/* ── OVERVIEW CARDS ── */
.overview-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 1rem; margin-bottom: 2rem; }
.ov-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem;
  cursor: pointer;
  transition: all 0.2s;
}
.ov-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.ov-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
.ov-title { font-family: var(--head); font-weight: 700; font-size: 0.9rem; color: var(--text); margin-bottom: 0.25rem; }
.ov-count { font-family: var(--mono); font-size: 0.75rem; color: var(--text3); }
.ov-bar { height: 3px; background: var(--surface3); border-radius: 2px; margin-top: 0.75rem; overflow: hidden; }
.ov-fill { height: 100%; border-radius: 2px; }

/* ── SEARCH ── */
.search-bar {
  display: flex; align-items: center; gap: 0.75rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.6rem 1rem;
  margin-bottom: 1.5rem;
}
.search-bar input {
  flex: 1; background: none; border: none; outline: none;
  color: var(--text); font-family: var(--body); font-size: 0.875rem;
}
.search-bar input::placeholder { color: var(--text3); }
.search-bar svg { color: var(--text3); flex-shrink: 0; }

/* ── COMMAND QUICK REF ── */
.cmd-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.cmd-item {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.75rem;
}
.cmd-item-title { font-size: 0.72rem; color: var(--text3); font-family: var(--mono); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }
.cmd-item code {
  font-family: var(--mono); font-size: 0.78rem; color: #79c0ff;
  display: block; line-height: 1.6;
}

/* ── PROGRESS BAR (study tracker) ── */
.progress-section { margin-bottom: 2rem; }
.progress-item { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
.progress-label { font-size: 0.8rem; color: var(--text2); width: 160px; flex-shrink: 0; }
.progress-bar { flex: 1; height: 6px; background: var(--surface3); border-radius: 3px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 3px; transition: width 0.5s; }
.progress-pct { font-family: var(--mono); font-size: 0.72rem; color: var(--text3); width: 35px; text-align: right; }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .sidebar { display: none; }
  .header-stats { display: none; }
  .cmd-grid { grid-template-columns: 1fr; }
}

.no-results { text-align: center; padding: 3rem; color: var(--text3); font-size: 0.9rem; }
</style>


  
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="header-brand">
    <div class="header-logo">OS</div>
    <div>
      <div class="header-title">OS Admin L3 — Interview Prep Hub</div>
      <div class="header-sub">Mumbai | 10+ Years | Complete Reference Guide</div>
    </div>
  </div>
  <div class="header-stats">
    <div class="hstat"><div class="hstat-n">150+</div><div class="hstat-l">Questions</div></div>
    <div class="hstat"><div class="hstat-n">12</div><div class="hstat-l">Topics</div></div>
    <div class="hstat"><div class="hstat-n">6</div><div class="hstat-l">OS Types</div></div>
    <div class="hstat"><div class="hstat-n">OCA/OCP</div><div class="hstat-l">Certified</div></div>
  </div>
</header>

<div class="layout">
<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-section-header">Navigation</div>
    <div class="sidebar-item active" onclick="showTab('overview')">
      <div class="sidebar-dot" style="background:#00d4ff"></div> Overview
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-header">🐧 Linux / RHEL</div>
    <div class="sidebar-item" onclick="showTab('patching')">
      <div class="sidebar-dot" style="background:#10b981"></div> Patching & Package Mgmt <span class="sidebar-count">8</span>
    </div>
    <div class="sidebar-item" onclick="showTab('boot')">
      <div class="sidebar-dot" style="background:#3b82f6"></div> Boot Process & GRUB <span class="sidebar-count">6</span>
    </div>
    <div class="sidebar-item" onclick="showTab('lvm')">
      <div class="sidebar-dot" style="background:#8b5cf6"></div> LVM & Storage <span class="sidebar-count">10</span>
    </div>
    <div class="sidebar-item" onclick="showTab('security')">
      <div class="sidebar-dot" style="background:#ef4444"></div> Security & Hardening <span class="sidebar-count">10</span>
    </div>
    <div class="sidebar-item" onclick="showTab('performance')">
      <div class="sidebar-dot" style="background:#f59e0b"></div> Performance & Troubleshoot <span class="sidebar-count">12</span>
    </div>
    <div class="sidebar-item" onclick="showTab('networking')">
      <div class="sidebar-dot" style="background:#06b6d4"></div> Networking & DNS <span class="sidebar-count">8</span>
    </div>
    <div class="sidebar-item" onclick="showTab('scripting')">
      <div class="sidebar-dot" style="background:#84cc16"></div> Shell Scripting <span class="sidebar-count">6</span>
    </div>
    <div class="sidebar-item" onclick="showTab('errors')">
      <div class="sidebar-dot" style="background:#f87171"></div> Common Errors & Fixes <span class="sidebar-count">10</span>
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-header">☁ VMware</div>
    <div class="sidebar-item" onclick="showTab('vmware')">
      <div class="sidebar-dot" style="background:#60a5fa"></div> VMware Administration <span class="sidebar-count">10</span>
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-header">🔆 Solaris</div>
    <div class="sidebar-item" onclick="showTab('solaris')">
      <div class="sidebar-dot" style="background:#fbbf24"></div> Solaris 10/11 & ZFS <span class="sidebar-count">8</span>
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-header">🖥 IBM AIX</div>
    <div class="sidebar-item" onclick="showTab('aix')">
      <div class="sidebar-dot" style="background:#a78bfa"></div> AIX & IBM Systems <span class="sidebar-count">6</span>
    </div>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-header">📋 ITSM & Process</div>
    <div class="sidebar-item" onclick="showTab('itsm')">
      <div class="sidebar-dot" style="background:#34d399"></div> ITSM, Incidents & Change <span class="sidebar-count">8</span>
    </div>
    <div class="sidebar-item" onclick="showTab('quickref')">
      <div class="sidebar-dot" style="background:#00d4ff"></div> Quick Command Reference
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">

<!-- ═══════════════════════════════════════════════════ OVERVIEW -->
<div id="tab-overview" class="tab-panel active">
  <div class="page-header">
    <div class="page-header-row">
      <div class="page-icon" style="background:linear-gradient(135deg,#00d4ff22,#3b82f622)">🎯</div>
      <div>
        <div class="page-title">Interview Preparation Hub</div>
        <div class="page-desc">Complete OS Administration L3 interview guide covering RHEL, Solaris, AIX, VMware, LVM, Networking, Security, ITSM and more. All questions from your sessions organized by topic.</div>
        <div class="page-tags">
          <span class="tag" style="color:#00d4ff;border-color:#00d4ff40">OCA/OCP</span>
          <span class="tag" style="color:#10b981;border-color:#10b98140">RHCSA/RHCE</span>
          <span class="tag" style="color:#f59e0b;border-color:#f59e0b40">Solaris 10/11</span>
          <span class="tag" style="color:#8b5cf6;border-color:#8b5cf640">IBM AIX</span>
          <span class="tag" style="color:#3b82f6;border-color:#3b82f640">ITIL</span>
          <span class="tag" style="color:#ef4444;border-color:#ef444440">VMware</span>
        </div>
      </div>
    </div>
  </div>

  <div class="overview-grid">
    <div class="ov-card" onclick="showTab('patching')">
      <div class="ov-icon">🔧</div>
      <div class="ov-title">Patching & Package Mgmt</div>
      <div class="ov-count">8 questions · RHEL / Solaris / AIX</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#10b981"></div></div>
    </div>
    <div class="ov-card" onclick="showTab('boot')">
      <div class="ov-icon">🚀</div>
      <div class="ov-title">Boot Process & GRUB</div>
      <div class="ov-count">6 questions · Kernel · initramfs</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#3b82f6"></div></div>
    </div>
    <div class="ov-card" onclick="showTab('lvm')">
      <div class="ov-icon">💾</div>
      <div class="ov-title">LVM & Storage</div>
      <div class="ov-count">10 questions · Multipath · Filesystem</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#8b5cf6"></div></div>
    </div>
    <div class="ov-card" onclick="showTab('security')">
      <div class="ov-icon">🔐</div>
      <div class="ov-title">Security & Hardening</div>
      <div class="ov-count">10 questions · SELinux · PAM · Auditd</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#ef4444"></div></div>
    </div>
    <div class="ov-card" onclick="showTab('performance')">
      <div class="ov-icon">⚡</div>
      <div class="ov-title">Performance & Troubleshoot</div>
      <div class="ov-count">12 questions · iostat · vmstat · iotop</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#f59e0b"></div></div>
    </div>
    <div class="ov-card" onclick="showTab('networking')">
      <div class="ov-icon">🌐</div>
      <div class="ov-title">Networking & DNS</div>
      <div class="ov-count">8 questions · Bonding · NFS · DNS</div>
      <div class="ov-bar"><div class="ov-fill" style="width:100%;background:#06b6d4"></div></div>
    </div>
