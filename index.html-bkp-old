<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>StudyHub — Technical Reference Index</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   ROOT & RESET
═══════════════════════════════════════════════ */
:root {
  --bg:         #080C10;
  --surface:    #0D1219;
  --card:       #111822;
  --card-hover: #161F2C;
  --border:     rgba(255,255,255,0.07);
  --border-h:   rgba(255,255,255,0.15);

  /* Accent palette — one per category */
  --net:   #00C8FF;  /* Networking   — electric cyan  */
  --linux: #39FF6E;  /* Linux/OS     — terminal green */
  --cloud: #FF6B35;  /* Cloud/HCI    — ember orange   */
  --itil:  #B87FFF;  /* ITIL/Process — violet         */
  --inter: #FFD700;  /* Interview    — gold           */
  --rhel:  #FF4C60;  /* RHEL         — red hot        */

  --text:   #E8EDF5;
  --muted:  #5A6A82;
  --dim:    #2A3548;

  --radius: 14px;
  --mono: 'JetBrains Mono', monospace;
  --display: 'Bebas Neue', sans-serif;
  --body: 'Outfit', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  -webkit-tap-highlight-color: transparent;
}

body {
  font-family: var(--body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════════════
   BACKGROUND FX
═══════════════════════════════════════════════ */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse 70% 50% at 15% 10%, rgba(0,200,255,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 85% 85%, rgba(255,107,53,0.06) 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 50% 50%, rgba(17,24,34,0.9) 0%, transparent 100%);
  pointer-events: none;
}

/* Dot grid */
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 0;
  background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events: none;
}

/* ═══════════════════════════════════════════════
   LAYOUT WRAPPER
═══════════════════════════════════════════════ */
.wrapper {
  position: relative; z-index: 1;
  max-width: 960px;
  margin: 0 auto;
  padding: 0 16px 80px;
}

/* ═══════════════════════════════════════════════
   HEADER
═══════════════════════════════════════════════ */
.header {
  padding: 52px 0 40px;
  text-align: center;
  position: relative;
}

.header-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 500;
  color: #A78BFA;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  background: rgba(139,92,246,0.07);
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 999px;
  padding: 5px 14px;
  margin-bottom: 20px;
}

.header-eyebrow .dot {
  width: 6px; height: 6px;
  background: #A78BFA;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.4; transform: scale(0.7); }
}

.header h1 {
  font-family: var(--display);
  font-size: clamp(3.2rem, 12vw, 5.5rem);
  line-height: 0.95;
  letter-spacing: 0.04em;
  color: #fff;
  margin-bottom: 6px;
}

.header h1 .accent {
  background: linear-gradient(90deg, var(--net), #7DF9FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-sub {
  font-size: 0.92rem;
  font-weight: 300;
  color: var(--muted);
  letter-spacing: 0.04em;
  margin-bottom: 28px;
}

/* Server info bar */
.server-bar {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: rgba(139,92,246,0.07);
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 10px;
  padding: 10px 18px;
  font-family: var(--mono);
  font-size: 0.72rem;
  color: #A78BFA;
}

.server-bar .srv-label {
  color: var(--muted);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.server-bar .srv-cmd {
  color: #A78BFA;
}

.server-bar .srv-sep { color: var(--dim); }

/* Stats row */
.stats-row {
  display: flex;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 24px;
}

.stat-chip {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 14px;
  font-size: 0.75rem;
  color: var(--muted);
}

.stat-chip strong { color: var(--text); font-weight: 600; }

/* ═══════════════════════════════════════════════
   SEARCH
═══════════════════════════════════════════════ */
.search-wrap {
  position: relative;
  margin: 0 0 36px;
}

.search-input {
  width: 100%;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 16px 14px 46px;
  font-family: var(--body);
  font-size: 0.95rem;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  -webkit-appearance: none;
}

.search-input:focus {
  border-color: rgba(0,200,255,0.35);
  box-shadow: 0 0 0 3px rgba(0,200,255,0.08), inset 0 1px 0 rgba(255,255,255,0.04);
}

.search-input::placeholder { color: var(--muted); }

.search-icon {
  position: absolute;
  left: 15px; top: 50%;
  transform: translateY(-50%);
  color: var(--muted);
  font-size: 1rem;
  pointer-events: none;
}

.search-clear {
  position: absolute;
  right: 12px; top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.06);
  border: none;
  border-radius: 6px;
  color: var(--muted);
  cursor: pointer;
  padding: 4px 8px;
  font-size: 0.75rem;
  display: none;
  font-family: var(--mono);
}

.search-input:not(:placeholder-shown) ~ .search-clear { display: block; }

/* ═══════════════════════════════════════════════
   QUICK-JUMP PILLS
═══════════════════════════════════════════════ */
.quickjump {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}

.qj-pill {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 14px;
  border-radius: 999px;
  font-size: 0.76rem;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid transparent;
  text-decoration: none;
  transition: all 0.18s;
  letter-spacing: 0.02em;
  -webkit-user-select: none;
}

.qj-pill .qj-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

.qj-net   { color: var(--net);   background: rgba(0,200,255,0.08);   border-color: rgba(0,200,255,0.2);   }
.qj-linux { color: var(--linux); background: rgba(57,255,110,0.08);  border-color: rgba(57,255,110,0.2);  }
.qj-cloud { color: var(--cloud); background: rgba(255,107,53,0.08);  border-color: rgba(255,107,53,0.2);  }
.qj-itil  { color: var(--itil);  background: rgba(184,127,255,0.08); border-color: rgba(184,127,255,0.2); }
.qj-inter { color: var(--inter); background: rgba(255,215,0,0.08);   border-color: rgba(255,215,0,0.2);   }
.qj-rhel  { color: var(--rhel);  background: rgba(255,76,96,0.08);   border-color: rgba(255,76,96,0.2);   }

.qj-pill:hover { transform: translateY(-1px); filter: brightness(1.15); }

/* ═══════════════════════════════════════════════
   SECTION LABEL
═══════════════════════════════════════════════ */
.section-label {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  margin-top: 36px;
}

.section-label:first-of-type { margin-top: 0; }

.sl-bar {
  width: 3px;
  height: 22px;
  border-radius: 2px;
  flex-shrink: 0;
}

.sl-title {
  font-family: var(--display);
  font-size: 1.25rem;
  letter-spacing: 0.06em;
  flex: 1;
}

.sl-count {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--muted);
  background: var(--dim);
  border-radius: 6px;
  padding: 3px 8px;
}

/* ═══════════════════════════════════════════════
   CARD GRID
═══════════════════════════════════════════════ */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 12px;
  margin-bottom: 8px;
}

/* ── Single card ── */
.card {
  position: relative;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  text-decoration: none;
  color: var(--text);
  display: flex;
  flex-direction: column;
  gap: 10px;
  overflow: hidden;
  transition: transform 0.18s, border-color 0.18s, background 0.18s, box-shadow 0.18s;
  -webkit-tap-highlight-color: transparent;
  cursor: pointer;
}

/* Accent top line */
.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c-accent, #fff);
  opacity: 0;
  transition: opacity 0.18s;
}

/* Glow wash */
.card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse 80% 60% at 50% -10%, var(--c-glow, rgba(0,0,0,0)) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.25s;
  pointer-events: none;
}

.card:hover {
  transform: translateY(-3px);
  border-color: var(--border-h);
  background: var(--card-hover);
  box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.3);
}

.card:hover::before { opacity: 1; }
.card:hover::after  { opacity: 1; }
.card:active        { transform: translateY(-1px); }

/* Card header row */
.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.card-icon {
  width: 40px; height: 40px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
  position: relative; z-index: 1;
}

.card-arrow {
  color: var(--muted);
  font-size: 1.1rem;
  transition: color 0.18s, transform 0.18s;
  margin-top: 2px;
}

.card:hover .card-arrow {
  color: var(--text);
  transform: translate(2px, -2px);
}

/* Card body */
.card-title {
  font-weight: 700;
  font-size: 0.97rem;
  line-height: 1.3;
  position: relative; z-index: 1;
}

.card-desc {
  font-size: 0.78rem;
  color: var(--muted);
  line-height: 1.5;
  position: relative; z-index: 1;
  flex: 1;
}

/* Card footer */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4px;
  position: relative; z-index: 1;
}

.card-tags {
  display: flex; gap: 5px; flex-wrap: wrap;
}

.tag {
  font-family: var(--mono);
  font-size: 0.6rem;
  padding: 2px 7px;
  border-radius: 4px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.card-size {
  font-family: var(--mono);
  font-size: 0.62rem;
  color: var(--dim);
}

/* ── Category colour variants ── */
/* Networking — cyan */
.c-net { --c-accent: var(--net); --c-glow: rgba(0,200,255,0.08); }
.c-net .card-icon { background: rgba(0,200,255,0.1); color: var(--net); }
.c-net .tag { background: rgba(0,200,255,0.1); color: var(--net); }

/* Linux / OS — green */
.c-linux { --c-accent: var(--linux); --c-glow: rgba(57,255,110,0.08); }
.c-linux .card-icon { background: rgba(57,255,110,0.1); color: var(--linux); }
.c-linux .tag { background: rgba(57,255,110,0.1); color: var(--linux); }

/* Cloud / HCI — orange */
.c-cloud { --c-accent: var(--cloud); --c-glow: rgba(255,107,53,0.08); }
.c-cloud .card-icon { background: rgba(255,107,53,0.1); color: var(--cloud); }
.c-cloud .tag { background: rgba(255,107,53,0.1); color: var(--cloud); }

/* ITIL / Process — violet */
.c-itil { --c-accent: var(--itil); --c-glow: rgba(184,127,255,0.08); }
.c-itil .card-icon { background: rgba(184,127,255,0.1); color: var(--itil); }
.c-itil .tag { background: rgba(184,127,255,0.1); color: var(--itil); }

/* Interview — gold */
.c-inter { --c-accent: var(--inter); --c-glow: rgba(255,215,0,0.08); }
.c-inter .card-icon { background: rgba(255,215,0,0.1); color: var(--inter); }
.c-inter .tag { background: rgba(255,215,0,0.1); color: var(--inter); }

/* RHEL — red */
.c-rhel { --c-accent: var(--rhel); --c-glow: rgba(255,76,96,0.08); }
.c-rhel .card-icon { background: rgba(255,76,96,0.1); color: var(--rhel); }
.c-rhel .tag { background: rgba(255,76,96,0.1); color: var(--rhel); }

/* ═══════════════════════════════════════════════
   FEATURED CARD (full-width highlight)
═══════════════════════════════════════════════ */
.card-featured {
  grid-column: 1 / -1;
  flex-direction: row;
  align-items: center;
  padding: 22px 24px;
  gap: 18px;
}

.card-featured .card-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  font-size: 1.5rem;
}

.card-featured .card-body { flex: 1; }

.card-featured .card-title { font-size: 1.05rem; }

.card-featured-badge {
  font-family: var(--mono);
  font-size: 0.6rem;
  color: var(--inter);
  background: rgba(255,215,0,0.1);
  border: 1px solid rgba(255,215,0,0.2);
  border-radius: 5px;
  padding: 2px 8px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  white-space: nowrap;
}

/* ═══════════════════════════════════════════════
   DIVIDER
═══════════════════════════════════════════════ */
.divider {
  height: 1px;
  background: var(--border);
  margin: 44px 0 0;
}

/* ═══════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════ */
.footer {
  text-align: center;
  padding: 40px 0 0;
  font-size: 0.72rem;
  color: var(--muted);
  font-family: var(--mono);
  line-height: 1.8;
}

.footer .f-host {
  color: #A78BFA;
  font-weight: 500;
}

/* ═══════════════════════════════════════════════
   EMPTY / NO RESULTS
═══════════════════════════════════════════════ */
.no-results {
  display: none;
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
}

.no-results .nr-icon { font-size: 2.5rem; margin-bottom: 12px; }
.no-results p { font-size: 0.88rem; }

/* ═══════════════════════════════════════════════
   ANIMATIONS
═══════════════════════════════════════════════ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

.header        { animation: fadeUp 0.5s ease both; }
.search-wrap   { animation: fadeUp 0.5s 0.08s ease both; }
.quickjump     { animation: fadeUp 0.5s 0.13s ease both; }
.section-label { animation: fadeUp 0.45s ease both; }
.card          { animation: fadeUp 0.4s ease both; }

/* Stagger cards */
.card:nth-child(1) { animation-delay: 0.05s; }
.card:nth-child(2) { animation-delay: 0.1s;  }
.card:nth-child(3) { animation-delay: 0.15s; }
.card:nth-child(4) { animation-delay: 0.2s;  }
.card:nth-child(5) { animation-delay: 0.25s; }
.card:nth-child(6) { animation-delay: 0.3s;  }

/* ═══════════════════════════════════════════════
   MOBILE OPTIMISATIONS
═══════════════════════════════════════════════ */
@media (max-width: 600px) {
  .card-grid { grid-template-columns: 1fr; }
  .card-featured { flex-direction: column; align-items: flex-start; }
  .card-featured-badge { align-self: flex-start; }
  .stats-row { gap: 6px; }
  .quickjump { gap: 6px; }
  .header { padding: 36px 0 28px; }
}

@media (min-width: 601px) and (max-width: 800px) {
  .card-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>
<div class="wrapper">

  <!-- ══════════════ HEADER ══════════════ -->
  <header class="header">
    <div class="header-eyebrow">
      <span class="dot"></span>
      GitHub Pages · admvishal.github.io/Studyhtml
    </div>
    <h1>STUDY<span class="accent">HUB</span></h1>
    <p class="header-sub">Technical Reference Library &mdash; All guides, one place</p>
    <div class="server-bar">
      <span class="srv-label">Hosted on</span>
      <span class="srv-cmd">admvishal.github.io/Studyhtml</span>
      <span class="srv-sep">·</span>
      <span class="srv-label">also on</span>
      <span class="srv-cmd">localhost:8080</span>
    </div>
    <div class="stats-row">
      <div class="stat-chip"><strong>8</strong>&nbsp;Guides</div>
      <div class="stat-chip"><strong>6</strong>&nbsp;Topics</div>
      <div class="stat-chip"><strong>~1.4 MB</strong>&nbsp;Total</div>
      <div class="stat-chip"><strong>GitHub</strong>&nbsp;Pages</div>
    </div>
  </header>

  <!-- ══════════════ SEARCH ══════════════ -->
  <div class="search-wrap">
    <span class="search-icon">⌕</span>
    <input
      class="search-input"
      id="searchInput"
      type="search"
      placeholder="Search guides, topics, keywords…"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    >
    <button class="search-clear" id="searchClear" onclick="clearSearch()">✕ clear</button>
  </div>

  <!-- ══════════════ QUICK JUMP ══════════════ -->
  <div class="quickjump" id="quickjump">
    <a class="qj-pill qj-net"   href="#cat-networking">
      <span class="qj-dot" style="background:var(--net)"></span>Networking
    </a>
    <a class="qj-pill qj-linux" href="#cat-linux">
      <span class="qj-dot" style="background:var(--linux)"></span>Linux / OS
    </a>
    <a class="qj-pill qj-cloud" href="#cat-cloud">
      <span class="qj-dot" style="background:var(--cloud)"></span>Cloud / HCI
    </a>
    <a class="qj-pill qj-itil"  href="#cat-itil">
      <span class="qj-dot" style="background:var(--itil)"></span>ITIL / Process
    </a>
    <a class="qj-pill qj-inter" href="#cat-interview">
      <span class="qj-dot" style="background:var(--inter)"></span>Interview Prep
    </a>
    <a class="qj-pill qj-rhel"  href="#cat-rhel">
      <span class="qj-dot" style="background:var(--rhel)"></span>RHEL
    </a>
  </div>

  <!-- ══════════════ ALL CARDS CONTAINER ══════════════ -->
  <div id="allContent">

  <!-- ─────────── NETWORKING ─────────── -->
  <div class="section-label" id="cat-networking">
    <div class="sl-bar" style="background:var(--net)"></div>
    <span class="sl-title" style="color:var(--net)">Networking</span>
    <span class="sl-count">2 guides</span>
  </div>

  <div class="card-grid" data-cat="networking">

    <a class="card c-net card-featured"
       href="CCNA Study Notes.html"
       data-title="CCNA Study Notes"
       data-keywords="ccna cisco networking routing switching vlan ospf bgp acl nat stp">
      <div class="card-icon">📡</div>
      <div class="card-body">
        <div class="card-header" style="margin-bottom:6px">
          <div class="card-title">CCNA Study Notes</div>
          <div class="card-arrow">↗</div>
        </div>
        <div class="card-desc">Comprehensive Cisco CCNA reference — routing &amp; switching fundamentals, VLANs, STP, OSPF, BGP, ACLs, NAT, subnetting, and network troubleshooting.</div>
        <div class="card-footer">
          <div class="card-tags">
            <span class="tag">Cisco</span>
            <span class="tag">Routing</span>
            <span class="tag">Switching</span>
            <span class="tag">VLANs</span>
          </div>
          <span class="card-size">116 KB</span>
        </div>
      </div>
    </a>

    <a class="card c-net card-featured"
       href="Network Study Reference.html"
       data-title="Network Study Reference"
       data-keywords="network tcp ip udp dns dhcp http osi model protocols subnetting">
      <div class="card-icon">🌐</div>
      <div class="card-body">
        <div class="card-header" style="margin-bottom:6px">
          <div class="card-title">Network Study Reference</div>
          <div class="card-arrow">↗</div>
        </div>
